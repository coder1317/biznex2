{
  "name": "biznex2",
  "version": "2.0.0",
  "description": "Biznex v2 — Multi-Store POS & Inventory System for Desktop and Raspberry Pi",
  "author": "Biznex",
  "license": "ISC",
  "main": "electron-shell/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "nodemon --exec electron .",
    "start:server": "node server/server.js",
    "start:rpi": "SERVE_STATIC=true node server/server-rpi.js",
    "dev:server": "nodemon server/server.js",
    "backup:db": "node server/backup-db.js",
    "demo-data": "node scripts/generate-demo-data.js",
    "build:windows": "node scripts/build-windows.js",
    "lint": "eslint server/**/*.js client/**/*.js electron-shell/**/*.js *.js",
    "lint:fix": "eslint server/**/*.js client/**/*.js electron-shell/**/*.js *.js --fix",
    "test": "jest",
    "pack": "electron-builder --dir",
    "build:win": "electron-builder --win --x64",
    "build:linux": "electron-builder --linux --x64",
    "build:rpi": "electron-builder --linux --arm64",
    "package:rpi": "node scripts/package-rpi.mjs",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.biznex.bos2",
    "productName": "Biznex2",
    "copyright": "Copyright © 2026 Biznex",
    "compression": "normal",
    "directories": {
      "output": "../biznex2-dist",
      "buildResources": "build-assets"
    },
    "files": [
      "electron-shell/**/*",
      "server/**/*",
      "!server/biznex2.db",
      "!server/biznex2.db-wal",
      "!server/biznex2.db-shm",
      "!server/backups/**",
      "!server/logs/**",
      "client/**/*",
      "node_modules/**/*",
      "package.json",
      "!.env",
      "!.env.local",
      "README.md"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "certificateFile": null,
      "certificatePassword": null,
      "signingHashAlgorithms": [
        "sha256"
      ],
      "sign": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Biznex2"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    }
  },
  "dependencies": {
    "express": "^4.18.2",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "helmet": "^7.0.0",
    "express-rate-limit": "^6.10.0",
    "winston": "^3.11.0",
    "sql.js": "^1.8.0",
    "pg": "^8.11.3",
    "dotenv": "^16.3.1",
    "socket.io": "^4.5.4",
    "electron-updater": "^6.1.7"
  },
  "devDependencies": {
    "electron": "^27.0.0",
    "electron-builder": "^24.9.1",
    "nodemon": "^3.0.2",
    "jest": "^29.7.0",
    "eslint": "^8.51.0"
  }
}
