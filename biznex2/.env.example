# Biznex2 Environment Configuration
# Copy this to .env and customize for your environment

# ─── Environment ───────────────────────────────────────────────────────────
NODE_ENV=production

# ─── Server ────────────────────────────────────────────────────────────────
PORT=3000
API_BASE_URL=http://localhost:3000

# ─── Database ──────────────────────────────────────────────────────────────
# Leave empty for default (SQLite in user data directory)
# Or set to a custom path
# DB_PATH=/path/to/biznex2.db

# ─── Logging ───────────────────────────────────────────────────────────────
# Leave empty for default (user data directory)
# LOG_DIR=/path/to/logs

# ─── JWT Secrets (auto-generated on first run in packaged mode) ───────────
# For development, you can set these manually, or leave empty for auto-generation
# JWT_SECRET=your-super-secret-jwt-key-here-min-32-chars
# JWT_REFRESH_SECRET=your-secret-refresh-key-here-min-32-chars

# ─── Optional: PostgreSQL Support ──────────────────────────────────────────
# Uncomment and configure to use PostgreSQL instead of SQLite
# DB_TYPE=postgres
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=biznex2
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=your-password

# ─── Notes ─────────────────────────────────────────────────────────────────
# - JWT_SECRET and JWT_REFRESH_SECRET are auto-generated on first run
# - In packaged mode (Electron), files are stored in user data directory
# - In dev mode, files are stored in the project directory
# - Changing these values requires deleting the database to start fresh
