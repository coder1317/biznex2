# ─── Server ───────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── PostgreSQL ───────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/biznex_license

# ─── JWT ──────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_STRONG_SECRET_64_CHARS_MINIMUM
JWT_REFRESH_SECRET=CHANGE_ME_ANOTHER_STRONG_SECRET
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# ─── Admin bootstrap ─────────────────────────────────────
# The first admin account created at migration time
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=ChangeMe123!

# ─── License settings ────────────────────────────────────
# How many days the app works offline before re-validation is required
OFFLINE_GRACE_DAYS=7

# ─── Sync / backup storage ───────────────────────────────
# Folder on this server where SQLite backups are stored
BACKUP_DIR=./backups

# ─── Update manifest ─────────────────────────────────────
# Base public URL where installers are served from (can be same server or S3)
UPDATE_BASE_URL=https://your-server.example.com/releases

# ─── Crash reporting (Sentry) ────────────────────────────
# Create a separate Sentry project for the cloud server.
# Leave blank to disable crash reporting.
# SENTRY_DSN_CLOUD=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@oXXXXXX.ingest.sentry.io/XXXXXXX
