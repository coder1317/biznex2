# ─── Biznex BOS · Environment Configuration ────────────────────────────────
# Copy this file to .env and fill in your values.
# On Raspberry Pi this file lives in the project root next to package.json.

# ── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── API URL ─────────────────────────────────────────────────────────────────
# Desktop Electron: leave as localhost — preload.js overrides this.
# Raspberry Pi / web mode: set to the Pi's local IP so other devices can connect.
#   e.g.  API_BASE_URL=http://192.168.1.50:3000
API_BASE_URL=http://localhost:3000

# ── CORS ─────────────────────────────────────────────────────────────────────
# Leave empty to allow all origins (fine for a local network POS).
# For a public server, set to your domain: CORS_ORIGIN=https://yoursite.com
# CORS_ORIGIN=

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite (default — works out of the box on both Windows and RPi)
DB_TYPE=sqlite
DB_PATH=./server/biznex.db

# PostgreSQL (Phase 3 — for multi-device deployments)
# DB_TYPE=postgres
# DATABASE_URL=postgresql://biznex:password@localhost:5432/biznex
# PG_SSL=false

# ── Crash reporting (Sentry) ────────────────────────────────────────────────
# Create a free project at https://sentry.io to get your DSN.
# Leave blank to disable crash reporting in dev.
# SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@oXXXXXX.ingest.sentry.io/XXXXXXX

# ── Licensing / Cloud Server ─────────────────────────────────────────────────
# URL of your self-hosted Biznex cloud-server (used for license validation,
# backup sync, and auto-updates).  Change to your real domain once deployed.
LICENSE_SERVER_URL=http://localhost:4000

# Set to "true" during development to bypass the license check entirely.
# NEVER set this to true in a production build.
SKIP_LICENSE_CHECK=false

# ─── Security — CHANGE ALL IN PRODUCTION ─────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-secret
SESSION_SECRET=change-this-to-another-long-secret

# Admin secret for the embedded license server (proto-license-server.js)
# Must match LICENSE_ADMIN_SECRET in biznex-portal .env
LICENSE_ADMIN_SECRET=change-this-to-a-strong-admin-secret

# ── Printer ───────────────────────────────────────────────────────────────────
# Override the thermal printer interface. Defaults: Windows=printer:POS-58, Linux=/dev/usb/lp0
# PRINTER_INTERFACE=printer:YourPrinterName
