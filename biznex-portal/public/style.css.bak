/* ── Reset ──────────────────────────────────────────────────────────────────── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html { scroll-behavior: smooth; }

body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    background: #0f172a;
    color: #e2e8f0;
    min-height: 100vh;
}

a { color: #6366f1; text-decoration: none; }
a:hover { text-decoration: underline; }

/* ── Top Nav ────────────────────────────────────────────────────────────────── */
.topnav {
    height: 56px;
    background: #020617;
    border-bottom: 1px solid #1e293b;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 28px;
    position: sticky;
    top: 0;
    z-index: 100;
}
.topnav-left { display: flex; align-items: center; gap: 10px; }
.nav-logo-mark {
    width: 34px; height: 34px;
    background: linear-gradient(135deg, #4f46e5, #2563eb);
    border-radius: 9px;
    display: flex; align-items: center; justify-content: center;
    font-size: 12px; font-weight: 800; color: #fff; letter-spacing: 0.5px;
    flex-shrink: 0;
}
.nav-logo-mark.sm { width: 28px; height: 28px; font-size: 10px; border-radius: 7px; }
.nav-brand { font-size: 16px; font-weight: 800; color: #f1f5f9; letter-spacing: 1.5px; }
.nav-sub   { font-size: 11px; color: #475569; font-weight: 500; letter-spacing: 0.5px; }
.topnav-right { display: flex; gap: 8px; }
.nav-btn {
    padding: 6px 14px; border-radius: 7px; font-size: 13px; font-weight: 500;
    cursor: pointer; transition: all 0.15s;
    background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); color: #cbd5e1;
}
.nav-btn:hover { background: rgba(255,255,255,0.12); color: #f1f5f9; }
.nav-btn.outline {
    background: rgba(99,102,241,0.1); border-color: rgba(99,102,241,0.35); color: #818cf8;
}
.nav-btn.outline:hover { background: rgba(99,102,241,0.2); }

/* ── Pages ──────────────────────────────────────────────────────────────────── */
.page { min-height: calc(100vh - 56px); padding: 40px 24px 60px; }
.page.hidden { display: none !important; }

/* ── Hero ───────────────────────────────────────────────────────────────────── */
.hero { text-align: center; margin-bottom: 40px; }
.hero h1 { font-size: 32px; font-weight: 800; color: #f1f5f9; margin-bottom: 10px;
    background: linear-gradient(135deg,#a5b4fc,#38bdf8); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
.hero p  { font-size: 14px; color: #64748b; }

/* ── Plan Cards ─────────────────────────────────────────────────────────────── */
.plan-cards {
    display: flex; gap: 20px; justify-content: center; flex-wrap: wrap;
    max-width: 900px; margin: 0 auto 36px;
}
.plan-card {
    width: 240px; border-radius: 14px; padding: 22px 20px;
    border: 2px solid #1e293b; background: #1e293b;
    cursor: pointer; transition: all 0.2s; position: relative;
    display: flex; flex-direction: column; gap: 6px;
}
.plan-card:hover { transform: translateY(-3px); }

.plan-card.str           { border-color: rgba(99,102,241,0.25); }
.plan-card.str.selected  { border-color: #6366f1; box-shadow: 0 0 0 3px rgba(99,102,241,0.25), 0 8px 32px rgba(99,102,241,0.15); }
.plan-card.biz           { border-color: rgba(14,165,233,0.25); }
.plan-card.biz.selected  { border-color: #0ea5e9; box-shadow: 0 0 0 3px rgba(14,165,233,0.25), 0 8px 32px rgba(14,165,233,0.15); }
.plan-card.ent           { border-color: rgba(16,185,129,0.25); }
.plan-card.ent.selected  { border-color: #10b981; box-shadow: 0 0 0 3px rgba(16,185,129,0.25), 0 8px 32px rgba(16,185,129,0.15); }

.plan-badge-top {
    position: absolute; top: -10px; left: 50%; transform: translateX(-50%);
    background: linear-gradient(90deg,#0ea5e9,#2563eb);
    color: #fff; font-size: 9px; font-weight: 800; letter-spacing: 1px;
    padding: 2px 10px; border-radius: 999px;
}
.plan-icon      { font-size: 28px; margin-bottom: 4px; }
.plan-name      { font-size: 16px; font-weight: 800; color: #f1f5f9; }
.plan-type      { font-size: 11px; color: #64748b; font-weight: 500; }
.plan-device    { font-size: 11px; color: #475569; }
.plan-key-eg    { font-size: 10px; font-family: 'Courier New', monospace; letter-spacing: 1px;
    color: #334155; margin-top: 4px; }
.plan-features  { list-style: none; margin-top: 12px; display: flex; flex-direction: column; gap: 5px; }
.plan-features li { font-size: 11px; padding-left: 16px; position: relative; color: #64748b; }
.plan-features li::before { content: '✕'; position: absolute; left: 0; font-size: 10px; color: #ef4444; }
.plan-features li.yes { color: #94a3b8; }
.plan-features li.yes::before { content: '✓'; color: #22c55e; }

/* ── Form Card ──────────────────────────────────────────────────────────────── */
.form-card {
    max-width: 440px; margin: 0 auto;
    background: #1e293b; border: 1px solid #334155; border-radius: 16px;
    padding: 30px 32px 28px;
}
.form-card.center { display: flex; flex-direction: column; align-items: center; }
.form-card.center h2, .form-card.center .form-sub,
.form-card.center form, .form-card.center .form-foot { width: 100%; }
.form-card h2 { font-size: 20px; font-weight: 700; color: #f1f5f9; margin-bottom: 6px; }
.form-sub { font-size: 12px; color: #64748b; margin-bottom: 20px; }
.form-logo { margin-bottom: 20px; }
.highlight-str { color: #818cf8; font-weight: 700; }
.highlight-biz { color: #38bdf8; font-weight: 700; }
.highlight-ent { color: #34d399; font-weight: 700; }
.form-group { margin-bottom: 14px; }
.form-group label { display: block; font-size: 12px; font-weight: 500; color: #94a3b8; margin-bottom: 5px; }
.form-group input, .form-group select {
    width: 100%; padding: 10px 14px;
    background: #0f172a; border: 1px solid #334155; border-radius: 8px;
    color: #e2e8f0; font-size: 14px; outline: none;
    transition: border-color 0.15s;
}
.form-group input:focus, .form-group select:focus { border-color: #4f46e5; }
.form-group input::placeholder { color: #334155; }
.form-foot { font-size: 12px; color: #475569; text-align: center; margin-top: 16px; line-height: 1.8; }

/* ── Buttons ────────────────────────────────────────────────────────────────── */
.btn-primary {
    width: 100%; padding: 11px 20px; margin-top: 4px;
    background: linear-gradient(135deg, #4f46e5, #2563eb);
    color: #fff; border: none; border-radius: 9px;
    font-size: 14px; font-weight: 600; cursor: pointer;
    transition: opacity 0.15s, transform 0.1s;
    box-shadow: 0 4px 14px rgba(79,70,229,0.3);
}
.btn-primary:hover:not(:disabled) { opacity: 0.9; transform: translateY(-1px); }
.btn-primary:disabled { opacity: 0.5; cursor: not-allowed; }
.btn-primary.sm { width: auto; padding: 7px 16px; font-size: 13px; margin-top: 0; }
.btn-secondary {
    padding: 10px 20px; margin-top: 4px;
    background: rgba(255,255,255,0.06); border: 1px solid #334155;
    color: #94a3b8; border-radius: 9px; font-size: 13px; font-weight: 500; cursor: pointer;
    transition: all 0.15s;
}
.btn-secondary:hover { background: rgba(255,255,255,0.1); color: #e2e8f0; }
.btn-secondary.sm { padding: 6px 14px; font-size: 12px; }
.btn-danger {
    padding: 5px 12px; background: rgba(239,68,68,0.12); border: 1px solid rgba(239,68,68,0.3);
    color: #f87171; border-radius: 6px; font-size: 12px; cursor: pointer;
    transition: all 0.15s;
}
.btn-danger:hover { background: rgba(239,68,68,0.25); }
.btn-icon {
    width: 30px; height: 30px; border-radius: 6px; border: 1px solid #1e293b;
    background: rgba(255,255,255,0.04); color: #64748b; cursor: pointer; font-size: 14px;
    display: flex; align-items: center; justify-content: center; transition: all 0.15s;
}
.btn-icon:hover { background: rgba(255,255,255,0.1); color: #e2e8f0; }

/* ── Alerts ─────────────────────────────────────────────────────────────────── */
.alert {
    margin-top: 12px; padding: 10px 14px; border-radius: 8px;
    font-size: 13px; line-height: 1.5;
}
.alert.error   { background: rgba(127,29,29,0.4); border: 1px solid #7f1d1d; color: #fca5a5; }
.alert.success { background: rgba(5,46,22,0.5);   border: 1px solid #14532d; color: #86efac; }
.alert.info    { background: rgba(12,26,46,0.6);   border: 1px solid #1e3a5f; color: #93c5fd; }

/* ── Success Card ───────────────────────────────────────────────────────────── */
.success-card {
    max-width: 520px; margin: 0 auto;
    background: #1e293b; border: 1px solid #334155; border-radius: 20px;
    padding: 36px 38px; text-align: center;
}
.success-icon { font-size: 46px; margin-bottom: 14px; }
.success-card h2 { font-size: 22px; font-weight: 800; color: #f1f5f9; margin-bottom: 8px; }
.success-card p  { font-size: 13px; color: #64748b; margin-bottom: 22px; }
.key-display {
    background: #0f172a; border: 1px solid #334155; border-radius: 12px;
    padding: 20px 24px; margin-bottom: 16px; position: relative;
}
.key-label  { font-size: 10px; font-weight: 700; color: #475569; letter-spacing: 1px;
    text-transform: uppercase; margin-bottom: 10px; }
.key-mono   { font-family: 'Courier New', monospace; font-size: 22px; font-weight: 700;
    letter-spacing: 3px; color: #a5b4fc; margin-bottom: 14px; word-break: break-all; }
.btn-copy   { padding: 7px 20px; background: rgba(99,102,241,0.15); border: 1px solid rgba(99,102,241,0.4);
    color: #818cf8; border-radius: 7px; font-size: 13px; font-weight: 600; cursor: pointer;
    transition: all 0.15s; }
.btn-copy:hover { background: rgba(99,102,241,0.3); }
.key-meta   { font-size: 12px; color: #475569; margin-bottom: 16px; line-height: 1.8; }
.success-actions { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; margin-top: 16px; }
.success-actions .btn-primary { width: auto; }

/* ── Dashboard Layout ───────────────────────────────────────────────────────── */
.dash-layout {
    display: flex; min-height: calc(100vh - 56px);
    padding: 0; background: #0f172a;
}
#page-dashboard { padding: 0; }

/* Sidebar */
.dash-sidebar {
    width: 220px; background: #020617;
    border-right: 1px solid #1e293b;
    display: flex; flex-direction: column;
    flex-shrink: 0; position: sticky; top: 56px;
    height: calc(100vh - 56px); overflow-y: auto;
}
.ds-brand {
    padding: 18px 16px 14px;
    border-bottom: 1px solid #1e293b;
    display: flex; align-items: center; gap: 10px;
}
.ds-brand-name { font-size: 14px; font-weight: 800; color: #f1f5f9; letter-spacing: 1px; }
.ds-brand-sub  { font-size: 9px; color: #475569; text-transform: uppercase; letter-spacing: 0.5px; }
.ds-nav { padding: 10px 8px; flex: 1; }
.ds-nav-item {
    display: flex; align-items: center; gap: 10px; width: 100%;
    padding: 10px 14px; margin-bottom: 4px; border-radius: 8px;
    background: none; border: none; color: #64748b;
    font-size: 13px; font-weight: 500; cursor: pointer;
    transition: all 0.15s; text-align: left;
}
.ds-nav-item:hover  { background: rgba(255,255,255,0.06); color: #cbd5e1; }
.ds-nav-item.active { background: #2563eb; color: #fff; font-weight: 600; }
.ds-footer {
    padding: 12px 14px; border-top: 1px solid #1e293b;
    display: flex; align-items: center; gap: 8px;
}
.ds-avatar {
    width: 32px; height: 32px; border-radius: 50%;
    background: linear-gradient(135deg, #4f46e5, #2563eb);
    color: #fff; font-size: 11px; font-weight: 700;
    display: flex; align-items: center; justify-content: center; flex-shrink: 0;
}
.ds-user-info { flex: 1; min-width: 0; }
.ds-username  { font-size: 12px; font-weight: 600; color: #e2e8f0;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.ds-email     { font-size: 10px; color: #475569;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.ds-logout {
    width: 28px; height: 28px; border-radius: 7px;
    background: rgba(239,68,68,0.1); border: none;
    color: #f87171; cursor: pointer; font-size: 14px;
    display: flex; align-items: center; justify-content: center; flex-shrink: 0;
    transition: all 0.15s;
}
.ds-logout:hover { background: rgba(239,68,68,0.25); }

/* Dashboard content */
.dash-content { flex: 1; padding: 28px 32px; overflow-y: auto; }
.dash-tab { display: none; }
.dash-tab.active { display: block; }
.dash-header {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 24px;
}
.dash-header h2 { font-size: 20px; font-weight: 700; color: #f1f5f9; }
.plan-chip {
    padding: 4px 14px; border-radius: 999px;
    font-size: 11px; font-weight: 700; letter-spacing: 0.5px; text-transform: uppercase;
}
.plan-chip.starter    { background: rgba(99,102,241,0.15); color: #818cf8; border: 1px solid rgba(99,102,241,0.35); }
.plan-chip.business   { background: rgba(14,165,233,0.15); color: #38bdf8; border: 1px solid rgba(14,165,233,0.35); }
.plan-chip.enterprise { background: rgba(16,185,129,0.15); color: #34d399; border: 1px solid rgba(16,185,129,0.35); }
.plan-chip.trial      { background: rgba(245,158,11,0.15); color: #f59e0b; border: 1px solid rgba(245,158,11,0.35); }

/* KPI row */
.kpi-row { display: flex; gap: 14px; flex-wrap: wrap; margin-bottom: 24px; }
.kpi-card {
    flex: 1; min-width: 130px; background: #1e293b;
    border: 1px solid #334155; border-radius: 12px; padding: 16px 18px;
}
.kpi-card .kpi-val { font-size: 22px; font-weight: 800; color: #f1f5f9; margin-bottom: 3px; }
.kpi-card .kpi-lbl { font-size: 11px; color: #64748b; }

/* Store grid */
.store-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 14px; }
.store-item {
    background: #1e293b; border: 1px solid #334155; border-radius: 12px;
    padding: 16px 18px; display: flex; flex-direction: column; gap: 8px;
}
.store-item.inactive { opacity: 0.5; }
.store-item-head { display: flex; align-items: center; justify-content: space-between; }
.store-name { font-size: 14px; font-weight: 700; color: #e2e8f0; }
.store-badge {
    font-size: 9px; font-weight: 700; letter-spacing: 0.5px; text-transform: uppercase;
    padding: 2px 7px; border-radius: 4px;
}
.store-badge.active   { background: rgba(34,197,94,0.15); color: #22c55e; border: 1px solid rgba(34,197,94,0.3); }
.store-badge.inactive { background: rgba(100,116,139,0.15); color: #64748b; border: 1px solid rgba(100,116,139,0.3); }
.store-loc { font-size: 11px; color: #64748b; }
.store-type-tag {
    display: inline-block; font-size: 10px; font-weight: 600;
    padding: 2px 8px; border-radius: 4px; border: 1px solid #1e293b;
    background: rgba(255,255,255,0.04); color: #475569;
}
.store-actions { display: flex; gap: 6px; flex-wrap: wrap; }

/* Full stores list */
.store-row {
    background: #1e293b; border: 1px solid #334155; border-radius: 10px;
    padding: 14px 16px; margin-bottom: 10px;
    display: flex; align-items: center; justify-content: space-between; gap: 12px;
    flex-wrap: wrap;
}
.store-row-info { flex: 1; min-width: 160px; }
.store-row-info .store-name { margin-bottom: 3px; }
.store-row-actions { display: flex; gap: 8px; align-items: center; }

/* Metrics panel */
.metrics-panel {
    background: #1e293b; border: 1px solid #334155; border-radius: 14px;
    padding: 22px 24px; margin-top: 20px;
}
.metrics-panel h4 { font-size: 15px; font-weight: 700; color: #e2e8f0; margin-bottom: 16px; }
.metrics-grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(140px,1fr)); gap: 12px;
    margin-bottom: 18px;
}
.metric-card {
    background: #0f172a; border: 1px solid #1e293b; border-radius: 10px; padding: 14px;
}
.metric-card .m-val { font-size: 20px; font-weight: 800; color: #f1f5f9; margin-bottom: 2px; }
.metric-card .m-lbl { font-size: 11px; color: #475569; }
.top-products { margin-top: 12px; }
.top-products h5 { font-size: 12px; font-weight: 600; color: #64748b; margin-bottom: 8px;
    text-transform: uppercase; letter-spacing: 0.5px; }
.tp-row { display: flex; align-items: center; justify-content: space-between;
    padding: 6px 0; border-bottom: 1px solid #0f172a; }
.tp-row:last-child { border: none; }
.tp-name { font-size: 13px; color: #94a3b8; }
.tp-val  { font-size: 13px; font-weight: 700; color: #e2e8f0; }

/* License detail */
.license-detail-card {
    background: #1e293b; border: 1px solid #334155; border-radius: 14px; padding: 24px 28px;
    max-width: 480px;
}
.license-detail-card .key-section {
    background: #0f172a; border: 1px solid #1e293b; border-radius: 10px; padding: 16px;
    margin: 16px 0;
}
.license-detail-card .ld-row {
    display: flex; justify-content: space-between; align-items: center;
    padding: 8px 0; border-bottom: 1px solid #1e293b; font-size: 13px;
}
.license-detail-card .ld-row:last-child { border: none; }
.ld-label { color: #64748b; }
.ld-value { color: #e2e8f0; font-weight: 600; }

/* ── Admin Layout ───────────────────────────────────────────────────────────── */
#page-admin { max-width: 960px; margin: 0 auto; }
.admin-layout { max-width: 960px; }
.admin-header {
    display: flex; align-items: flex-start; justify-content: space-between;
    gap: 20px; flex-wrap: wrap; margin-bottom: 32px;
}
.admin-header h2 { font-size: 22px; font-weight: 700; color: #f1f5f9; margin-bottom: 4px; }
.admin-header p  { font-size: 13px; color: #64748b; }
.admin-secret-input {
    padding: 8px 14px; background: #1e293b; border: 1px solid #334155;
    border-radius: 8px; color: #e2e8f0; font-size: 13px; outline: none; width: 220px;
}
.admin-secret-input:focus { border-color: #4f46e5; }
.admin-section {
    background: #1e293b; border: 1px solid #334155; border-radius: 14px;
    padding: 22px 24px; margin-bottom: 20px;
}
.admin-section h3 { font-size: 15px; font-weight: 700; color: #e2e8f0; margin-bottom: 16px; }
.admin-form { display: grid; grid-template-columns: 1fr 1fr 1fr auto; gap: 12px; align-items: end; }
@media (max-width: 700px) { .admin-form { grid-template-columns: 1fr; } }

/* Admin accounts table */
.accounts-table { width: 100%; border-collapse: collapse; font-size: 13px; }
.accounts-table th {
    text-align: left; padding: 8px 12px; font-size: 10px; font-weight: 700;
    color: #475569; text-transform: uppercase; letter-spacing: 0.5px;
    border-bottom: 1px solid #334155;
}
.accounts-table td { padding: 10px 12px; color: #94a3b8; border-bottom: 1px solid #1e293b; }
.accounts-table tr:last-child td { border: none; }
.accounts-table tr:hover td { background: rgba(255,255,255,0.02); }
.key-cell { font-family: 'Courier New', monospace; font-size: 11px; letter-spacing: 1px; color: #818cf8; }

/* Admin gen result */
#adminGenResult { margin-top: 14px; }
#adminGenResult .admin-key-out {
    background: #0f172a; border: 1px solid #334155; border-radius: 10px; padding: 16px;
    font-family: 'Courier New', monospace; font-size: 18px; font-weight: 700;
    letter-spacing: 2px; color: #a5b4fc; text-align: center;
}

/* ── Modal ──────────────────────────────────────────────────────────────────── */
.modal-overlay {
    position: fixed; inset: 0; background: rgba(0,0,0,0.7);
    display: flex; align-items: center; justify-content: center; z-index: 999;
}
.modal-overlay.hidden { display: none !important; }
.modal-box {
    background: #1e293b; border: 1px solid #334155; border-radius: 16px;
    padding: 28px 30px; width: 420px; max-width: 92vw;
}
.modal-box h3 { font-size: 16px; font-weight: 700; color: #f1f5f9; margin-bottom: 18px; }
.modal-actions { display: flex; gap: 10px; justify-content: flex-end; margin-top: 20px; }

/* ── Toast ──────────────────────────────────────────────────────────────────── */
#toast-area {
    position: fixed; bottom: 24px; right: 24px;
    display: flex; flex-direction: column; gap: 8px; z-index: 9999;
}
.toast {
    padding: 11px 16px; border-radius: 9px; font-size: 13px; font-weight: 500;
    max-width: 320px; opacity: 0; transform: translateX(20px);
    transition: all 0.3s; cursor: pointer;
}
.toast.show { opacity: 1; transform: translateX(0); }
.toast.success { background: #052e16; border: 1px solid #14532d; color: #86efac; }
.toast.error   { background: #450a0a; border: 1px solid #7f1d1d; color: #fca5a5; }
.toast.info    { background: #0c1a2e; border: 1px solid #1e3a5f; color: #93c5fd; }

/* ── Spinner ─────────────────────────────────────────────────────────────────── */
.spinner {
    display: inline-block; width: 14px; height: 14px;
    border: 2px solid rgba(255,255,255,0.3); border-top-color: #fff;
    border-radius: 50%; animation: spin 0.7s linear infinite;
    vertical-align: middle; margin-right: 6px;
}
@keyframes spin { to { transform: rotate(360deg); } }

/* ── Step indicator ─────────────────────────────────────────────────────────── */
.reg-steps {
    display: flex; align-items: center; justify-content: center;
    gap: 0; margin-bottom: 28px;
}
.reg-step {
    display: flex; flex-direction: column; align-items: center; gap: 4px;
    cursor: default;
}
.reg-step span {
    width: 32px; height: 32px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 13px; font-weight: 700;
    background: #1e293b; border: 2px solid #334155; color: #475569;
    transition: all 0.3s;
}
.reg-step small { font-size: 10px; color: #475569; white-space: nowrap; transition: color 0.3s; }
.reg-step.active span  { background: #4f46e540; border-color: #6366f1; color: #a5b4fc; }
.reg-step.active small { color: #a5b4fc; }
.reg-step.done span    { background: #4f46e5; border-color: #4f46e5; color: #fff; }
.reg-step.done small   { color: #818cf8; }
.reg-step-line {
    flex: 1; height: 2px; min-width: 40px;
    background: linear-gradient(90deg, #334155, #334155);
    margin-bottom: 16px; transition: background 0.3s;
}

/* ── OTP input row ──────────────────────────────────────────────────────────── */
.otp-row {
    display: flex; align-items: center; justify-content: center; gap: 8px;
    margin: 8px 0 4px;
}
.otp-box {
    width: 46px; height: 54px;
    background: #0f172a; border: 2px solid #334155; border-radius: 10px;
    color: #a5b4fc; font-size: 22px; font-weight: 700; font-family: 'Courier New', monospace;
    text-align: center; outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
}
.otp-box:focus {
    border-color: #6366f1; box-shadow: 0 0 0 3px rgba(99,102,241,0.2);
}
.otp-box:not(:placeholder-shown) { border-color: #4f46e5; }
.otp-divider { color: #475569; font-size: 20px; font-weight: 300; margin: 0 2px; }

/* ── Dev code box ───────────────────────────────────────────────────────────── */
.dev-code-box {
    background: #1a0a0a; border: 1px solid #7f1d1d;
    border-radius: 10px; padding: 14px 16px; margin-bottom: 18px; text-align: center;
}
.dev-code-label {
    font-size: 10px; font-weight: 700; letter-spacing: 1px;
    color: #f87171; text-transform: uppercase; margin-bottom: 8px;
}
.dev-code-val {
    font-family: 'Courier New', monospace; font-size: 28px; font-weight: 800;
    letter-spacing: 8px; color: #fca5a5;
}
.dev-code-hint { font-size: 11px; color: #6b7280; margin-top: 6px; }

/* ── Utility ─────────────────────────────────────────────────────────────────── */
.hidden { display: none !important; }
