# ─── Biznex Portal · Environment Configuration ─────────────────────────────
# Copy this file to .env and fill in your values.

PORT=5000
NODE_ENV=production

# ── Admin secret (REQUIRED in production) ────────────────────────────────────
# Used to protect /api/admin/* routes. Generate a strong random value.
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must match LICENSE_ADMIN_SECRET in the BOS app .env
ADMIN_SECRET=change-this-to-a-strong-admin-secret
LICENSE_ADMIN_SECRET=change-this-to-a-strong-admin-secret

# ── BOS license server sync ───────────────────────────────────────────────────
# URL of the embedded license server (proto-license-server.js) or cloud server
LICENSE_SERVER_URL=http://localhost:4000

# ── CORS ──────────────────────────────────────────────────────────────────────
# Set to your portal's public domain in production
# PORTAL_ORIGIN=https://portal.yourdomain.com

# ── SMTP (used to send OTP codes and license key emails) ──────────────────────
# Leave unset to run in dev mode (OTP codes appear in API responses)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM="Biznex <noreply@yourdomain.com>"
